# Environment Configuration for PhishGuard
# Copy this file to .env and fill in your values

# Flask Settings
FLASK_ENV=development
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# Server Settings
HOST=127.0.0.1
PORT=5000

# API Keys
VIRUSTOTAL_API_KEY=

# Security Scanning
MAX_HISTORY=10
SCAN_TIMEOUT=30

# SSL/TLS Settings
SSL_TIMEOUT=5
SSL_VERIFY=True

# WHOIS Settings
WHOIS_TIMEOUT=10

# VirusTotal Settings
VT_TIMEOUT=15
VT_MAX_RETRIES=6
VT_RETRY_DELAY=5

# Threat Scoring Weights
WHOIS_WEIGHT=1.0
SSL_WEIGHT=1.0
VT_WEIGHT=1.5
URL_WEIGHT=1.0
